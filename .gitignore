# Root workspace hygiene
__pycache__/
*.pyc
.DS_Store
Thumbs.db

# Local envs and runtime caches
.env
.env.*
.venv/
venv/

# Keep nested managed repositories independent
repos/*
!repos/README.md
!repos/index.json
!repos/pulse-ingestor-mvp/
!repos/pulse-ingestor-mvp/**

# Root supervisor runtime artifacts
codex-supervisor-mvp/state/*
!codex-supervisor-mvp/state/.gitkeep
