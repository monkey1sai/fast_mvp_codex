PULSE_DB_PATH=/app/runtime/pulse.db
PULSE_IMAP_HOST=
PULSE_IMAP_PORT=993
PULSE_IMAP_USERNAME=
PULSE_IMAP_PASSWORD=
PULSE_IMAP_MAILBOX=INBOX
PULSE_IMAP_PROCESSED_MAILBOX=AI新聞脈動PLUS
PULSE_IMAP_MOVE_ON_SUCCESS=true
PULSE_POLL_MAX_MESSAGES=10
PULSE_ALLOWED_FROM_PATTERNS=openai,chatgpt
PULSE_ALLOWED_SUBJECT_KEYWORDS=[任務更新],[task update],task update
PULSE_ALLOWED_BODY_KEYWORDS=從 chatgpt 更新任務,from chatgpt task update,chatgpt.com/c/,取消訂閱任務郵件,unsubscribe from task emails
PULSE_AUTO_POLL_ENABLED=false
PULSE_AUTO_POLL_INTERVAL_SECONDS=300
PULSE_API_PORT=8000
